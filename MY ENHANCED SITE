        a {
            color: hsl(0, 0%, 100%);
            background-color:rgb(83, 79, 79);
            padding: 8px 12px;
            border-radius: 5px;
            text-decoration: none;
            transition: background-color 0.3s;
        }

        a:hover {
            background-color: #910505;
        }

        /* Image styles */
        img {
            max-width: 100%;
            height: auto;
            border-radius: 8px;
            transition: transform 0.3s;
            width: 500px;height: 600px;
        }

        img:hover {
            transform: scale(1.05);
        }

        /* Table styles */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th, td {
            border: 1px solid #000;
            padding: 12px;
            text-align: left;
        }

        th {
            background-color: #96D4D4;
        }

        /* Form styles */
        form {
            background-color: #f4f4f4;
            padding: 20px;
            border-radius: 10px;
            max-width: 600px;
            margin: auto;
        }

        fieldset {
            border: 2px solid #ccc;
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 8px;
        }

        legend {
            padding: 0 10px;
            font-weight: bold;
            font-size: 1.2em;
        }

        label {
            display: block;
            margin-top: 10px;
            font-weight: bold;
        }

        input[type="text"],
